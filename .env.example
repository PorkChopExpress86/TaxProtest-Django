# Copy to .env and fill in real values. .env is git-ignored.
# These are the variables actually consumed by settings.py and the compose files.

# --- Django core ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me
# 0 in production. 1 only for local development.
DEBUG=0

# Comma-separated. Supply YOUR OWN host(s); do not rely on a built-in default.
ALLOWED_HOSTS=localhost,127.0.0.1
# Full https origin(s), comma-separated, e.g. https://tax.example.com
CSRF_TRUSTED_ORIGINS=
# Set ONLY if you terminate TLS at a reverse proxy and want that host trusted.
# Leave unset otherwise — there is no built-in default host anymore.
# REVERSE_PROXY_HOST=tax.example.com

# --- Postgres ---
POSTGRES_USER=taxprotest
# Generate a strong value: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=change-me
POSTGRES_DB=taxprotest

# --- Redis / Celery ---
# REQUIRED. Redis is password-protected (--requirepass). Generate a strong value:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=change-me
# The compose files build the broker URL from REDIS_PASSWORD; these are only
# needed if you run outside compose. Keep the password in the URL.
# CELERY_BROKER_URL=redis://:change-me@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:change-me@redis:6379/0

# --- Build ---
# 1 = skip HCAD download during `docker compose build` (fast dev/CI builds).
# Leave at 0 (or omit) for production builds that bake data into the image.
SKIP_DATA_DOWNLOAD=1
