# Copy to .env and fill in real values. .env is git-ignored.
# These are the variables consumed by settings.py and docker-compose.yaml.

# ── Django core ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me

# 0 in production. 1 only for local development.
DEBUG=0

# Comma-separated. Include all hostnames/IPs that will serve the app.
ALLOWED_HOSTS=localhost,127.0.0.1

# Full https origins, comma-separated. Required when DEBUG=0.
# e.g. https://tax.example.com
CSRF_TRUSTED_ORIGINS=

# Set only if TLS is terminated at a reverse proxy and you need that host
# added to ALLOWED_HOSTS automatically. Leave unset otherwise.
# REVERSE_PROXY_HOST=tax.example.com

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL  (default: INFO)
LOG_LEVEL=INFO

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=taxprotest
POSTGRES_USER=taxprotest
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=change-me

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Required — Redis is password-protected (--requirepass).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=change-me

# ── Email (contact form) ──────────────────────────────────────────────────────
# Leave EMAIL_HOST unset to use the console backend (dev). Set it to enable SMTP.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=change-me

# Destination address for contact form submissions (default: blake.b.8726@gmail.com).
# CONTACT_EMAIL=you@example.com

# ── Build ─────────────────────────────────────────────────────────────────────
# 1 = skip HCAD download during `docker compose build` (fast dev/CI builds).
# 0 (or omit) = bake fresh data into the image (production builds).
SKIP_DATA_DOWNLOAD=1

# ── Optional security overrides ───────────────────────────────────────────────
# Uncomment when running behind a TLS-terminating reverse proxy.
# USE_X_FORWARDED_HOST=1
# ENABLE_SECURE_PROXY_SSL_HEADER=1
# ENABLE_SECURE_SETTINGS=1
# SECURE_HSTS_SECONDS=604800
