# Copy this file to .env and fill in values
DJANGO_SECRET_KEY=replace-with-a-strong-random-string
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=replace-with-a-strong-admin-password
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,property.ohmygoshwhatever.com
CSRF_TRUSTED_ORIGINS=https://property.ohmygoshwhatever.com
POSTGRES_DB=taxprotest
POSTGRES_USER=taxprotest
POSTGRES_PASSWORD=change-me
# Keep DATABASE_URL in sync with the credentials above
DATABASE_URL=postgresql://taxprotest:change-me@db:5432/taxprotest
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
LOG_LEVEL=INFO
HCAD_DOWNLOAD_DIR=/app/var/downloads
HCAD_EXTRACT_DIR=/app/var/extracted
HCAD_LOG_DIR=/app/var/logs
PROJECT_REPORT_DIR=/app/var/reports
